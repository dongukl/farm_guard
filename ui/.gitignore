# Local environment
.env
.env.*
!.env.example
.venv/
venv/
backend/.venv/

# Python cache / test artifacts
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Node dependencies and generated files
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Accidental npm lockfiles outside the frontend app
/package-lock.json
/backend/package-lock.json

# IDE / local tool metadata
.vscode/
.agents/
.codex/

# Backend runtime data
backend/*.sqlite3
backend/*.sqlite3-*
backend/latest_webcam.jpg
backend/recordings/

# ROS / colcon build artifacts
build/
install/
log/
backend/build/
backend/install/
backend/log/

# Downloaded model weights
backend/*.pt

# Keep required frontend static assets even if a parent .gitignore ignores images.
!frontend/public/
!frontend/public/images/
!frontend/public/images/*.png
!frontend/public/images/*.jpg
!frontend/public/images/*.jpeg
